{
  "name": "dentur-manager-front",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:server": "npm --prefix backend run dev",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "build:server": "npm --prefix backend run build"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.2.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
